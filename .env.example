# =============================================================================
# Payment Gateway Service - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env files to version control!
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL)
# -----------------------------------------------------------------------------
# Default for docker-compose: postgres:5432 (internal) or localhost:5433 (external)
DATASOURCE_URL=jdbc:postgresql://localhost:5433/payment_gateway
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=your_secure_password_here

# Database pool settings (optional - defaults shown)
DATASOURCE_MAX_POOL_SIZE=10
DATASOURCE_MIN_IDLE=5

# -----------------------------------------------------------------------------
# KAFKA CONFIGURATION
# -----------------------------------------------------------------------------
# Default for docker-compose: localhost:9093
KAFKA_BOOTSTRAP_SERVERS=localhost:9093

# Kafka consumer group (optional)
KAFKA_CONSUMER_GROUP_ID=payment-gateway-group

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION (Idempotency)
# -----------------------------------------------------------------------------
# Default for docker-compose: localhost:6380
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local

# -----------------------------------------------------------------------------
# AWS CONFIGURATION (S3 for Report Storage - Optional)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=payment-gateway-reports

# -----------------------------------------------------------------------------
# STRIPE CONFIGURATION (Payment Provider - Optional)
# -----------------------------------------------------------------------------
# Use test keys for development!
# Test keys format: sk_test_... and pk_test_...
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# -----------------------------------------------------------------------------
# JWT CONFIGURATION (Authentication)
# -----------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_key_min_32_characters_long_for_security
JWT_EXPIRATION_MS=86400000

# -----------------------------------------------------------------------------
# ENCRYPTION CONFIGURATION (PCI-DSS Compliance)
# -----------------------------------------------------------------------------
# 256-bit encryption key for sensitive data at rest
ENCRYPTION_KEY=your_32_character_encryption_key!
ENCRYPTION_ALGORITHM=AES/GCM/NoPadding

# -----------------------------------------------------------------------------
# MONITORING & OBSERVABILITY
# -----------------------------------------------------------------------------
# Prometheus/Grafana (optional)
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin

# Zipkin Tracing (optional)
ZIPKIN_BASE_URL=http://localhost:9411

# -----------------------------------------------------------------------------
# RATE LIMITING (Bucket4j / Resilience4j)
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20
